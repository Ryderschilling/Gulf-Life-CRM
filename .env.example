# ── Supabase (database + login) ──────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── OpenAI (AI assistant, drafts, daily briefing) ────────────
OPENAI_API_KEY=

# ── Resend (1-on-1 email sending) ────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=crm@thriveco.net
RESEND_FROM_NAME=Gulf Life Concierge

# ── Quo (SMS — John's number lives in Quo, formerly OpenPhone)
# Get the key: Quo web app → Settings → API
QUO_API_KEY=
QUO_FROM_NUMBER=+18505550100

# ── Mailchimp (marketing audience sync) ──────────────────────
# Key: Mailchimp → Account → Extras → API keys (looks like xxxx-us21)
# Audience ID: Audience → Settings → Audience name and defaults
MAILCHIMP_API_KEY=
MAILCHIMP_AUDIENCE_ID=
